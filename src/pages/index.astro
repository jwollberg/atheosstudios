---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout>
  <a class="skip" href="#main">Skip to content</a>

  <header class="site">
    <div class="wrap nav">
      <a class="brand" href="#top" aria-label="Atheos Studios home">
        <img class="logo" src="/brand-kit/logo.png" alt="Atheos Studios" width="972" height="330" />
      </a>
      <nav class="navlinks" aria-label="Primary">
        <a href="#games">Games</a>
        <a href="#about">Studio</a>
        <a href="#contact">Contact</a>
        <a class="cta" href="https://graveerrorgame.com">Grave Error</a>
      </nav>
      <button class="navtoggle" id="navbtn" aria-expanded="false" aria-controls="mobilemenu">Menu +</button>
    </div>
    <div id="mobilemenu">
      <a href="#games">Games</a>
      <a href="#about">Studio</a>
      <a href="#contact">Contact</a>
      <a href="https://graveerrorgame.com">Grave Error →</a>
    </div>
  </header>

  <main id="main">
    <a id="top"></a>

    <!-- HERO -->
    <section class="hero">
      <div class="wrap hero-inner">
        <div class="hero-tag lbl">
          <span>Independent Game Studio</span>
          <span class="r">Est. 2024 — atheosstudios.com</span>
        </div>
        <h1 class="bigword">ATHEOS<br /><span class="out">STUDIOS</span></h1>
        <div class="hero-mid">
          <p class="mission">
            We make realism-first survival games — worlds built with care, and
            <b>no promises you'll make it through the night.</b>
          </p>
          <div class="hero-cta">
            <a class="btn btn-primary" href="https://graveerrorgame.com">Grave Error →</a>
            <a class="btn" href="#games">Our games</a>
          </div>
        </div>
      </div>
    </section>
    <div class="strip" aria-hidden="true">
      <div class="track">
        <span><b>GRAVE ERROR</b></span><span>·</span><span>COMING SOON</span><span>·</span><span>EARLY ACCESS</span><span>·</span><span>SUMMER 2026</span><span>·</span><span><b>GRAVE ERROR</b></span><span>·</span><span>COMING SOON</span><span>·</span><span>EARLY ACCESS</span><span>·</span><span>SUMMER 2026</span><span>·</span><span><b>GRAVE ERROR</b></span><span>·</span><span>COMING SOON</span><span>·</span><span>EARLY ACCESS</span><span>·</span><span>SUMMER 2026</span><span>·</span><span><b>GRAVE ERROR</b></span><span>·</span><span>COMING SOON</span><span>·</span><span>EARLY ACCESS</span><span>·</span><span>SUMMER 2026</span><span>·</span>
      </div>
    </div>

    <!-- GAMES -->
    <section class="sec" id="games">
      <div class="wrap sec-head">
        <h2>The Games</h2>
        <span class="idx lbl">01 / Catalogue</span>
      </div>
      <article class="feature">
        <div
          class="keyart"
          role="img"
          aria-label="Grave Error key art: a stark tombstone silhouette split by a jagged crack under a cold sky."
        >
          <svg viewBox="0 0 560 560" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
            <rect width="560" height="560" fill="#262b33"></rect>
            <!-- halftone sky dots -->
            <g fill="#3a4049">
              <circle cx="60" cy="60" r="3"></circle><circle cx="120" cy="90" r="2"></circle><circle cx="200" cy="50" r="3"></circle>
              <circle cx="300" cy="80" r="2"></circle><circle cx="420" cy="55" r="3"></circle><circle cx="500" cy="100" r="2"></circle>
              <circle cx="90" cy="150" r="2"></circle><circle cx="470" cy="150" r="3"></circle><circle cx="380" cy="130" r="2"></circle>
            </g>
            <!-- ground -->
            <rect y="420" width="560" height="140" fill="#1a1e24"></rect>
            <path d="M0 420 L560 420 L560 440 L0 452 Z" fill="#31363f"></path>
            <!-- tombstone -->
            <g>
              <path d="M180 430 L180 220 a100 100 0 0 1 200 0 L380 430 Z" fill="#fbfaf7"></path>
              <!-- crack -->
              <path
                d="M282 150 L268 230 L296 250 L262 330 L292 350 L270 430"
                fill="none"
                stroke="#262b33"
                stroke-width="7"
                stroke-linejoin="round"></path>
              <!-- engraved text marks -->
              <rect x="220" y="270" width="120" height="8" fill="#262b33" opacity=".55"></rect>
              <rect x="235" y="292" width="90" height="8" fill="#262b33" opacity=".45"></rect>
              <rect x="245" y="314" width="70" height="8" fill="#262b33" opacity=".35"></rect>
            </g>
            <!-- clawing hands -->
            <g stroke="#fbfaf7" stroke-width="8" stroke-linecap="round" fill="none" opacity=".9">
              <path d="M110 470 v-46 M128 470 v-60 M146 470 v-44 M164 468 v-52"></path>
            </g>
            <g stroke="#fbfaf7" stroke-width="8" stroke-linecap="round" fill="none" opacity=".9">
              <path d="M400 476 v-40 M418 476 v-56 M436 476 v-42"></path>
            </g>
          </svg>
          <span class="coming">● Coming soon</span>
        </div>
        <div class="fbody">
          <div class="titlebar">
            <h3>Grave<br />Error</h3>
            <span class="genre lbl">Top-Down Zombie Survival</span>
          </div>
          <p>
            It began with a software update. The HACK program placed adaptive nanobots in billions
            of minds — then Core Update 3.0 shipped with a fatal flaw, and the bodies got back up.
            You play a Null, one of the few the implants never took, loose in a procedurally
            generated world of dead cities and open highways. Real day and night. Weather that
            matters. Vehicles, firearms, and hordes that hunt by sight and sound. Built
            realism-first — alone or with friends, you don't beat this world, you outlast it.
          </p>
          <dl class="specs">
            <div><dt>Genre</dt><dd>Zombie Survival</dd></div>
            <div><dt>Mode</dt><dd>Single & Multiplayer</dd></div>
            <div><dt>Platforms</dt><dd>PC</dd></div>
            <div><dt>Status</dt><dd>Early Access · Summer 2026</dd></div>
          </dl>
          <a class="btn btn-primary" href="https://graveerrorgame.com">Learn more →</a>
        </div>
      </article>
    </section>

    <!-- ABOUT -->
    <section class="sec" id="about">
      <div class="wrap sec-head">
        <h2>The Studio</h2>
        <span class="idx lbl">02 / Who</span>
      </div>
      <div class="wrap about-grid">
        <div class="about-left">
          <h2>Realism<br />First.<br />No<br />Filler.</h2>
        </div>
        <div class="about-right">
          <p>
            <b>Atheos Studios is an independent game developer</b> making survival games the slow,
            honest way. Every system — hunger, weather, wounds, the way a horde hears you — is
            built with care and intention, so the world feels real enough to be worth surviving.
          </p>
          <p class="pull">We build the dark and then we ask you to survive it.</p>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="sec" id="contact">
      <div class="wrap sec-head">
        <h2>Contact</h2>
        <span class="idx lbl">03 / Signal</span>
      </div>
      <div class="wrap contact-body">
        <p>Business and press inquiries — or just to tell us how long you lasted. We read everything.</p>
        <a class="mailbig" href="mailto:info@atheosstudios.com">info@<wbr />atheosstudios.com</a>
      </div>
    </section>
  </main>

  <footer class="site">
    <div class="wrap foot">
      <span>© 2026 Atheos Studios</span>
      <span class="r">Realism-first survival games</span>
      <span>atheosstudios.com</span>
    </div>
  </footer>

  <script is:inline>
    (function () {
      var btn = document.getElementById("navbtn");
      var menu = document.getElementById("mobilemenu");
      if (!btn || !menu) return;
      btn.addEventListener("click", function () {
        var open = menu.classList.toggle("open");
        btn.setAttribute("aria-expanded", open ? "true" : "false");
        btn.textContent = open ? "Close ×" : "Menu +";
      });
      menu.querySelectorAll("a").forEach(function (a) {
        a.addEventListener("click", function () {
          menu.classList.remove("open");
          btn.setAttribute("aria-expanded", "false");
          btn.textContent = "Menu +";
        });
      });
    })();
  </script>
</SiteLayout>
